# --- Database ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql://root:password@localhost:3306/zob
DB_POOL_SIZE=10

# --- Auth (recommended) ---
# Used to encrypt session cookies.
AUTH_SECRET=change-me-to-a-long-random-string

# --- VATSIM OAuth (optional) ---
VATSIM_CLIENT_ID=
VATSIM_CLIENT_SECRET=
VATSIM_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- GitHub Wiki (optional overrides) ---
GITHUB_WIKI_OWNER=mjbeck1234
GITHUB_WIKI_REPO=test-wiki
GITHUB_WIKI_BRANCH=main
GITHUB_WIKI_DIR=wiki
GITHUB_TOKEN=

# --- Scheddy (training sessions) ---
# Master/API key used for server-side requests to Scheddy. Do NOT expose this in client-side code.
SCHEDDY_API_MASTER_KEY=

# --- Stored site integration (optional) ---
# If your downloads table contains relative file paths that still live on the previous PHP site,
# set this so /downloads can resolve them correctly (example: https://existing.clevelandcenter.org).
DOWNLOADS_SITE_BASE_URL=

# Optional: link directly to the downloads archive page (if you want an "archive" link on the new /downloads page).
DOWNLOADS_ARCHIVE_URL=
